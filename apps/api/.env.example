# Server Configuration
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# PocketBase Configuration (for development, use localhost)
# For production, use your actual domain
WEBSITE_DOMAIN=localhost:8090
PB_SUPERUSER_EMAIL=admin@vegamailer.local
PB_SUPERUSER_PASSWORD=admin123456

# Email Service API Keys
# Get your API keys from:
# Plunk: https://app.useplunk.com/settings/project
# Resend: https://resend.com/api-keys
# These are optional for development, but required for sending emails
PLUNK_API_KEY=your_plunk_api_key_here
RESEND_API_KEY=your_resend_api_key_here
